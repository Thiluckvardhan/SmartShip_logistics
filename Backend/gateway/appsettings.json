{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "identity-auth": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "identity-users": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        }
      },
      "identity-roles": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/roles/{**catch-all}"
        }
      },
      "shipment-shipments": {
        "ClusterId": "shipment-cluster",
        "Match": {
          "Path": "/api/shipments/{**catch-all}"
        }
      },
      "shipment-prefixed": {
        "ClusterId": "shipment-cluster",
        "Match": {
          "Path": "/shipment/api/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/shipment"
          }
        ]
      },
      "shipment-addresses": {
        "ClusterId": "shipment-cluster",
        "Match": {
          "Path": "/api/addresses/{**catch-all}"
        }
      },
      "shipment-packages": {
        "ClusterId": "shipment-cluster",
        "Match": {
          "Path": "/api/packages/{**catch-all}"
        }
      },
      "shipment-pickups": {
        "ClusterId": "shipment-cluster",
        "Match": {
          "Path": "/api/pickups/{**catch-all}"
        }
      },
      "tracking-api": {
        "ClusterId": "tracking-cluster",
        "Match": {
          "Path": "/api/tracking/{**catch-all}"
        }
      },
      "document-api": {
        "ClusterId": "document-cluster",
        "Match": {
          "Path": "/api/documents/{**catch-all}"
        }
      },
      "admin-api": {
        "ClusterId": "admin-cluster",
        "Match": {
          "Path": "/api/admin/{**catch-all}"
        }
      },
      "identity-swagger": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/swagger/gatewaydocs/identity/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/swagger/{**catch-all}"
          }
        ]
      },
      "shipment-swagger": {
        "ClusterId": "shipment-cluster",
        "Match": {
          "Path": "/swagger/gatewaydocs/shipment/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/swagger/{**catch-all}"
          }
        ]
      },
      "tracking-swagger": {
        "ClusterId": "tracking-cluster",
        "Match": {
          "Path": "/swagger/gatewaydocs/tracking/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/swagger/{**catch-all}"
          }
        ]
      },
      "document-swagger": {
        "ClusterId": "document-cluster",
        "Match": {
          "Path": "/swagger/gatewaydocs/document/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/swagger/{**catch-all}"
          }
        ]
      },
      "admin-swagger": {
        "ClusterId": "admin-cluster",
        "Match": {
          "Path": "/swagger/gatewaydocs/admin/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/swagger/{**catch-all}"
          }
        ]
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:8001"
          }
        }
      },
      "shipment-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:8002"
          }
        }
      },
      "tracking-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:8003"
          }
        }
      },
      "document-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:8004"
          }
        }
      },
      "admin-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:8005"
          }
        }
      }
    }
  }
}
